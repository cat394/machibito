---
import ViewTransitions from 'astro/components/ViewTransitions.astro';

type Props = {
  title: string;
  content: string;
}
const { title, content } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja" data-theme="dracula" class="bg-[#030303] font-serif">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={content} />
    <link rel="apple-touch-icon" sizes="76x76" href="/assets/favicon_package/apple-touch-icon.png">
    <link rel="android-chrome" sizes="96x96" href="/assets/favicon_package/android-chrome-96x96.png">
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon_package/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon_package/favicon-16x16.png">
    <link rel="manifest" href="/assets/favicon_package/site.webmanifest">
    <link rel="mask-icon" href="/assets/favicon_package/safari-pinned-tab.svg" color="#5bbad5">
    <meta name="msapplication-TileColor" content="#da532c">
    <meta name="theme-color" content="#ffffff">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <title>{title}</title>
    <script type="application/ld+json">
      {
        "@context": "http://schema.org",
        "@type": "CreativeWork",
        "name": "待ち人",
        "author": {
          "@type": "Person",
          "name": "りょう"
        },
        "description": "『伝え忘れてしまった想いが、あなたにはありますか？』もうやってこないだろうあの日に待ち続ける2人の影がいた。夕焼け空に鈴の音が響くとき、彼らの運命は彷徨い始める。あのときの想いが、言葉が、幻想的な世界の背景で錯綜する。文章と画像と曲が混ざり合い、織り成される、ビジュアルノベル風ウェブサイト。",
        "datePublished": "2023-08-15",
        "url": "https://machibito.app/",
        "image": {
          "@type": "ImageObject",
          "url": "https://res.cloudinary.com/drnqfkovd/image/upload/v1692096867/machibito-title_screen_fc06rh.jpg",
          "height": 563,
          "width": 1000
        }
      }
    </script>
    <ViewTransitions />
  </head>
  <slot />
</html>