---
import Layout from "../layouts/Layout.astro";
import Form from "../components/form/Form.svelte";
import Spacer from "../components/spacer/Spacer.svelte";
import Divider from "../components/divider/Divider.svelte";
import StickyNote from "../components/stickyNote/stickyNote.svelte";

const title = "お問い合わせ";
const content = "『待ち人』の作者、りょうへのお問い合わせフォームです。作品へのコメント、誤字の報告など、どんなご意見もお気軽にお寄せください。";
---

<Layout title={title} content={content}>
  <p>
    本作品に対するコメントや誤字報告など、お気軽にお問い合わせ下さい。<br>
    X（旧Twitter）のDMも開放しているため、そちらをお使いになられても構いません。<br>
    いただいた情報は私以外の者と共有することはございませんので、ご安心ください。
  </p>
  <Divider />
  <StickyNote type="warn">
    <p>現在（2023/08/16）、フォームが機能しない不具合が発生しているため、何か用事がありましたらお手数ですがページ下部のリンクのSNSアカウントよりご連絡ください。</p>
  </StickyNote>
  <Spacer />
  <h2 class="text-center italic text-xl">Contact</h2>
  <Spacer templates="low" />
  <form class="grid gap-10" netlify data-netlify-honeypot="bot-field" name="feedback" method="POST">
    <input type="hidden" name="form-name" value="feedback">
    <label>
      <div class="mb-3">お名前（ニックネーム可）：</div>
      <input class="input input-bordered input-secondary w-full " name="name" placeholder="Type your name">
    </label> 
    <label>
      <div class="mb-3">メールアドレス：</div> 
      <input class="input input-bordered input-secondary w-full " name="email" placeholder="Type your email" type="email">
    </label> 
    <label>
      <div class="mb-3">内容：</div> 
      <textarea class="textarea textarea-secondary w-full h-[20vh] text-base pt-3" placeholder="Type your message" name="message" required></textarea>
    </label> 
    <p class="hidden">
      <label>あなたが人間である場合は、これに記入しないでください: 
        <input name="bot-field">
      </label>
    </p>
    <div class="flex justify-center">
      <button class="btn btn-wide btn-secondary text-neutral-50" type="submit">
        送信する<span class="material-symbols-rounded">forward_to_inbox</span>
      </button>
    </div>
  </form>
</Layout>